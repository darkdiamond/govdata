# GovData configuration

# CKAN API
CKAN_BASE_URL=https://data.gov.il/api/3/action
CKAN_REQUEST_DELAY=0.5

# Firestore (scanner + builder)
FIRESTORE_PROJECT_ID=govdata-il
# Or point at a local emulator (uncomment):
# FIRESTORE_EMULATOR_HOST=localhost:8080

# Cloud Run builder
ANTHROPIC_API_KEY=
# IDs produced by `bash infra/setup-agent.sh` (run once).
ANTHROPIC_AGENT_ID=
ANTHROPIC_ENV_ID=
# Staging bucket the agent artifacts land in; publisher syncs from here.
GCS_STAGING_BUCKET=govdata-il-staging
# Firebase/GCP project for Hosting + Cloud Build
FIREBASE_PROJECT=govdata-il
# Cloud Build trigger ID created by infra/bootstrap.sh
PUBLISH_TRIGGER_ID=govdata-publish
PUBLISH_BRANCH=main
# How many sources to process per scheduler tick. Bump carefully (memory scales).
N_PER_RUN=1
# Upper bound on datasets fetched from CKAN per scan pass.
SCAN_LIMIT=500

# Optional: embedding provider
VOYAGE_API_KEY=

# Logging
LOG_LEVEL=INFO
