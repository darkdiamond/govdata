# govil.ai configuration — copy to .env and fill in.
# .env is gitignored; never commit real secrets.

# --- CKAN (scanner) ---
CKAN_BASE_URL=https://data.gov.il/api/3/action
CKAN_REQUEST_DELAY=0.5
# Upper bound on datasets fetched from CKAN per scan pass.
SCAN_LIMIT=500

# --- Firestore (scanner + builder) ---
FIRESTORE_PROJECT_ID=govdata-il
# Or point at a local emulator for development (uncomment):
# FIRESTORE_EMULATOR_HOST=localhost:8080

# --- Agent runtime (OpenRouter) ---
# Get a key at https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=
# Any OpenRouter "<vendor>/<model>" id; default is minimax/minimax-m3.
OPENROUTER_MODEL=minimax/minimax-m3
# How many sources to process per scheduler tick (memory scales with this).
DAILY_CAP=1
# Per-source concurrency inside the single builder container.
MAX_CONCURRENT=4
# In-run retries per source before it's marked failed.
SESSION_ATTEMPTS=3

# --- Staging + hosting ---
# Staging bucket the agent artifacts land in; the publisher syncs from here.
GCS_STAGING_BUCKET=govdata-il-staging
# Firebase / GCP project for Hosting + deploys.
FIREBASE_PROJECT=govdata-il

# --- Publish trigger ---
# Where the builder dispatches the publish workflow (owner/repo).
PUBLISH_GITHUB_REPO=darkdiamond/govdata
PUBLISH_BRANCH=main
# github | cloudbuild — how publishing is triggered.
PUBLISH_VIA=github
# Token used to dispatch the GitHub Actions publish workflow (PUBLISH_VIA=github).
GITHUB_DISPATCH_TOKEN=
# Cloud Build fallback (PUBLISH_VIA=cloudbuild).
PUBLISH_TRIGGER_ID=govdata-publish
PUBLISH_REGION=me-west1

# Set to false to pause Track 2 re-analysis of already-published pages.
# Track 1 (never-analyzed sources) is unaffected.
REANALYZE_ENABLED=true

# --- Optional: frontend analytics/ads (nuxt generate time) ---
# All three are off when unset: the generated site contains no GA, AdSense,
# or Clarity code, and no ads.txt is emitted. Production sets these as
# GitHub repo variables consumed by .github/workflows/publish.yml.
NUXT_PUBLIC_GTAG_ID=
NUXT_PUBLIC_ADSENSE_ID=
NUXT_PUBLIC_CLARITY_ID=

# --- Optional: embedding-driven relatedness (Voyage) ---
VOYAGE_ENABLED=false
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-4

# --- Logging ---
LOG_LEVEL=INFO

# Optional: derived Podman image for the local test harness (pandas
# preinstalled — see services/page_builder/sandbox.Containerfile).
# PODMAN_SANDBOX_IMAGE=localhost/govdata-sandbox:latest
