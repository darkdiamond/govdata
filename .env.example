# GovData Scanner Configuration

# CKAN API Settings
CKAN_BASE_URL=https://data.gov.il/api/3/action
CKAN_REQUEST_DELAY=0.5

# Storage Paths
DATA_DIR=./data
DOWNLOADS_DIR=./data/downloads
DB_PATH=./data/scanner.db

# Scanner Defaults
DEFAULT_LIMIT=5
DEFAULT_TIMEOUT=30

# Logging
LOG_LEVEL=INFO

# Page builder (optional — scanner fires a webhook per NEW/UPDATED dataset)
PAGE_BUILDER_URL=

# Cloud Function environment (page_builder only — not read by the scanner)
ANTHROPIC_API_KEY=
# IDs produced by `bash infra/setup-agent.sh` (run once).
# Agent = persistent, versioned config (model, system prompt, tools).
# Environment = per-session container template (networking, packages).
ANTHROPIC_AGENT_ID=
ANTHROPIC_ENV_ID=
GCS_CONTENT_BUCKET=
CLOUDFLARE_BUILD_HOOK=
