<!DOCTYPE html>
<html dir="rtl" lang="he">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ entry.title }} — GovData.IL</title>
  <meta name="description" content="{{ description }}">
  <meta property="og:type" content="article">
  <meta property="og:title" content="{{ entry.title }}">
  <meta property="og:description" content="{{ description }}">
  <meta name="twitter:card" content="summary">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Rubik:wght@300;400;500;600;700&display=swap">

  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    // Keep these tokens in sync with frontend/tailwind.config.ts.
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            brand: {
              DEFAULT: '#0068f5',
              50:  '#f1f7ff', 100: '#dbe8fb', 200: '#b7d2f7',
              500: '#0068f5', 600: '#0053c4', 700: '#0b3668', 800: '#0c3058',
            },
            ink:           '#0c3058',
            'ink-deep':    '#0b3668',
            surface:       '#f1f7ff',
            'surface-alt': '#f0f4fa',
            rule:          '#c3cfe7',
            subtle:        '#6c757d',
            ok:            '#198754',
            warn:          '#ffc107',
            danger:        '#dc3545',
            info:          '#0dcaf0',
          },
          fontFamily: {
            sans:    ['Rubik', 'system-ui', 'Arial', 'sans-serif'],
            display: ['Rubik', 'system-ui', 'sans-serif'],
          },
          borderRadius: {
            'gov-sm':   '0.2rem',
            'gov-md':   '0.3rem',
            gov:        '0.5rem',
            'gov-pill': '50rem',
          },
          maxWidth: { gov: '1400px' },
          backgroundImage: {
            'gov-header': 'linear-gradient(90deg, #025fdb 0%, #0b3668 100%)',
          },
          boxShadow: {
            card:         '0 1px 2px rgba(12, 48, 88, 0.06)',
            'card-hover': '0 6px 24px -8px rgba(0, 104, 245, 0.18)',
          },
          spacing: { header: '64px' },
        },
      },
    };
  </script>
  <style>
    html { font-family: Rubik, system-ui, Arial, sans-serif; color: #0c3058; background: #f1f7ff; }
    body { line-height: 1.5; }
    h1, h2, h3, h4, h5, h6 { font-family: Rubik, system-ui, sans-serif; line-height: 1.2; font-weight: 500; color: #0c3058; }
    h1 { font-size: clamp(1.625rem, 1.3875rem + 1.65vw, 2.625rem); }
    h2 { font-size: clamp(1.5rem,   1.3375rem + 1.05vw, 2.125rem); margin-top: 1.5rem; margin-bottom: 0.75rem; }
    h3 { font-size: clamp(1.3125rem, 1.275rem + 0.3vw,  1.5rem);   margin-top: 1rem;   margin-bottom: 0.5rem;  }
    h4 { font-size: 1.125rem; }
    h5 { font-size: 1rem; }
    h6 { font-size: 0.875rem; }
    a        { color: #0068f5; }
    a:hover  { color: #0053c4; text-decoration: underline; }
    .card { background: #fff; border: 1px solid #c3cfe7; border-radius: 0.5rem; box-shadow: 0 1px 2px rgba(12,48,88,0.06); }
    .card-hover { transition: box-shadow .15s; }
    .card-hover:hover { box-shadow: 0 6px 24px -8px rgba(0,104,245,0.18); }
    .tag-chip { display: inline-block; padding: 2px 8px; font-size: .75rem; background: #f1f7ff; color: #0c3058; border: 1px solid #dbe8fb; border-radius: 50rem; }
    .badge { display: inline-block; padding: 2px 8px; font-size: .75rem; background: #fff; color: #6c757d; border: 1px solid #c3cfe7; border-radius: 0.2rem; }
    .btn-primary { display: inline-flex; align-items: center; gap: .5rem; background: #0068f5; color: #fff; border-radius: 0.5rem; padding: .5rem 1rem; text-decoration: none; transition: background-color .15s; }
    .btn-primary:hover { background: #0053c4; text-decoration: none; color: #fff; }
    .btn-ghost { display: inline-flex; align-items: center; gap: .5rem; color: #0068f5; border: 1px solid #0068f5; border-radius: 0.5rem; padding: .5rem 1rem; text-decoration: none; transition: background-color .15s; }
    .btn-ghost:hover { background: #f1f7ff; text-decoration: none; }
    .quality-track { height: .5rem; background: #c3cfe7; border-radius: 50rem; overflow: hidden; }
    .quality-fill  { height: 100%; background: #0068f5; }
    .gov-header { background-image: linear-gradient(90deg, #025fdb 0%, #0b3668 100%); color: #fff; }
    .leaflet-container { direction: ltr; }
    .leaflet-popup-content { direction: rtl; text-align: right; }
  </style>
</head>
<body class="min-h-screen flex flex-col bg-surface">
  <header class="gov-header">
    <div class="max-w-gov mx-auto px-4 h-header flex items-center justify-between gap-6">
      <a href="/" class="flex items-center gap-3 no-underline hover:no-underline text-white">
        <span class="w-9 h-9 rounded-gov bg-white/15 grid place-items-center text-white text-base font-display">GD</span>
        <span class="font-display text-lg leading-none">GovData.IL</span>
      </a>
      <nav class="hidden md:flex items-center gap-6 text-sm">
        <a href="/" class="text-white/85 hover:text-white no-underline hover:no-underline">ראשי</a>
        <a href="/ministries/" class="text-white/85 hover:text-white no-underline hover:no-underline">משרדים</a>
        <a href="/tags/" class="text-white/85 hover:text-white no-underline hover:no-underline">נושאים</a>
      </nav>
      <a
        href="https://data.gov.il"
        target="_blank" rel="noopener"
        class="hidden sm:inline-flex items-center gap-2 text-xs text-white/85 hover:text-white no-underline hover:no-underline"
      >
        <img src="/icons/external-link.svg" alt="" class="w-4 h-4 invert opacity-90" />
        data.gov.il
      </a>
    </div>
  </header>

  <nav aria-label="breadcrumb" class="border-b border-rule bg-white">
    <div class="max-w-gov mx-auto px-4 py-2 text-xs text-subtle">
      <a href="/">ראשי</a>
      {% if entry.organization and entry.organization_slug %}
        <span class="mx-1">›</span>
        <a href="/ministries/{{ entry.organization_slug }}/">{{ entry.organization }}</a>
      {% endif %}
      <span class="mx-1">›</span>
      <span>{{ entry.title }}</span>
    </div>
  </nav>

  <div class="max-w-gov mx-auto px-4 py-8 grid grid-cols-1 lg:grid-cols-[1fr_280px] gap-8 flex-1">
    <main>
      {{ content | safe }}
    </main>

    <aside class="space-y-4">
      {% if related %}
      <section class="card p-4">
        <h3 class="m-0 mb-3 text-sm text-subtle font-display">מאגרים קשורים</h3>
        <ul class="list-none m-0 p-0 space-y-2">
          {% for r in related %}
          <li>
            <a href="/datasets/{{ r.id }}/" class="block card-hover p-2 rounded-gov-md hover:bg-brand-50 no-underline hover:no-underline">
              <div class="text-sm font-medium text-ink">{{ r.title }}</div>
              {% if r.organization %}<div class="text-xs text-subtle mt-0.5">{{ r.organization }}</div>{% endif %}
              {% if r.summary_he %}<div class="text-xs text-subtle mt-1 line-clamp-2">{{ r.summary_he }}</div>{% endif %}
            </a>
          </li>
          {% endfor %}
        </ul>
      </section>
      {% endif %}

      {% if entry.tags_he %}
      <section class="card p-4">
        <h3 class="m-0 mb-2 text-sm text-subtle font-display">תגיות</h3>
        <div class="flex flex-wrap gap-1">
          {% for t in entry.tags_he %}
          <a href="/tags/{{ t }}/" class="tag-chip hover:bg-brand-100">{{ t }}</a>
          {% endfor %}
        </div>
      </section>
      {% endif %}

      {% if entry.dataset_kind %}
      <section class="card p-4 text-xs text-subtle">
        סוג מאגר:
        <a href="/kinds/{{ entry.dataset_kind }}/" class="badge hover:bg-brand-50">{{ kind_label }}</a>
      </section>
      {% endif %}
    </aside>
  </div>

  <footer class="bg-ink-deep text-white mt-16">
    <div class="max-w-gov mx-auto px-4 py-10 grid grid-cols-1 md:grid-cols-3 gap-8 text-sm">
      <div>
        <div class="font-display text-base mb-2">GovData.IL</div>
        <p class="text-white/75 leading-relaxed m-0">
          דפי נחיתה אוטומטיים למאגרי המידע הציבוריים של ממשלת ישראל,
          מבוססים על
          <a href="https://data.gov.il" target="_blank" rel="noopener" class="text-white underline">data.gov.il</a>.
        </p>
      </div>
      <div>
        <div class="font-display text-base mb-2">ניווט</div>
        <ul class="list-none p-0 m-0 space-y-1.5">
          <li><a href="/" class="text-white/85 hover:text-white no-underline hover:no-underline">ראשי</a></li>
          <li><a href="/ministries/" class="text-white/85 hover:text-white no-underline hover:no-underline">משרדים</a></li>
          <li><a href="/tags/" class="text-white/85 hover:text-white no-underline hover:no-underline">נושאים</a></li>
        </ul>
      </div>
      <div>
        <div class="font-display text-base mb-2">מקור</div>
        <ul class="list-none p-0 m-0 space-y-1.5 text-white/85">
          <li>
            <a href="https://data.gov.il" target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 hover:text-white no-underline hover:no-underline">
              <img src="/icons/external-link.svg" alt="" class="w-4 h-4 invert opacity-90" />
              data.gov.il
            </a>
          </li>
          <li>
            <a href="https://www.gov.il" target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 hover:text-white no-underline hover:no-underline">
              <img src="/icons/external-link.svg" alt="" class="w-4 h-4 invert opacity-90" />
              gov.il
            </a>
          </li>
        </ul>
      </div>
    </div>
    <div class="border-t border-white/10">
      <div class="max-w-gov mx-auto px-4 py-4 text-xs text-white/70 flex flex-col sm:flex-row sm:justify-between gap-2">
        <div>תוכן שנוצר אוטומטית ממידע ציבורי.</div>
        <div>© {{ year }} GovData.IL</div>
      </div>
    </div>
  </footer>
</body>
</html>
